# Environment
NODE_ENV=development
PORT=5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=VendorBridge Prourement ERP    
DB_USER=postgres
DB_PASSWORD=Ahmadhaiwalapg

# Session
SESSION_SECRET=generate-strong-random-string-64-chars
SESSION_SECURE=false # true in production

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your googl;e
SMTP_PASS=your pass

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=5

# PDF Generation
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox